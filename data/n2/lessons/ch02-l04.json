    {
      "id": "ch02-l04-210",
      "index": 210,
      "word": "購入（こうにゅう）〈する〉",
      "reading": "こうにゅう",
      "meaning": {
        "en": "purchase",
        "zh": "購買，購入"
      },
      "sentence": {
        "ja": "重たい物はインターネットで購入する。 重的東西就在網上買。",
        "zh": "[相關]：販売〈する〉 (sell / 銷售)"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch02-l04-211",
      "index": 211,
      "word": "［お］買い得（おかいどく）",
      "reading": "おかいどく",
      "meaning": {
        "en": "bargain",
        "zh": "划算，特價"
      },
      "sentence": {
        "ja": "スーパーのお買い得商品を毎日チェックしている。",
        "zh": "我每天都去看看超市的特價商品。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch02-l04-212",
      "index": 212,
      "word": "手頃な（てごろな）",
      "reading": "てごろな",
      "meaning": {
        "en": "affordable",
        "zh": "適合，稱手"
      },
      "sentence": {
        "ja": "あの店には、学生に手頃な値段の物がたくさんある。",
        "zh": "那家店有很多學生們買得起的東西。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch02-l04-213",
      "index": 213,
      "word": "値引き（ねびき）〈する〉",
      "reading": "ねびき",
      "meaning": {
        "en": "discount",
        "zh": "打折"
      },
      "sentence": {
        "ja": "デパートの食品売り場は夜8時になると、値引きする。 商場的食品櫃台到了晚上8點就打折。",
        "zh": "[相關]：まける (discount / 便宜)"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch02-l04-214",
      "index": 214,
      "word": "おまけ〈する〉",
      "reading": "おまけ〈する〉",
      "meaning": {
        "en": "extra",
        "zh": "折扣；贈品"
      },
      "sentence": {
        "ja": "①近くの八百屋で100円おまけしてくれた。②りんごを買ったら、みかんをおまけしてくれた。",
        "zh": "①在附近的蔬菜店買菜時，老闆給我便宜了100日元。②買蘋果時贈送了橘子。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch02-l04-215",
      "index": 215,
      "word": "返品（へんぴん）〈する〉",
      "reading": "へんぴん",
      "meaning": {
        "en": "returns",
        "zh": "退貨"
      },
      "sentence": {
        "ja": "ネットの写真と違う商品が届いたので、返品した。",
        "zh": "收到的東西跟網上照片上的一不一樣，所以我退貨了。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch02-l04-216",
      "index": 216,
      "word": "返金（へんきん）〈する〉",
      "reading": "へんきん",
      "meaning": {
        "en": "repayment",
        "zh": "退錢，退款"
      },
      "sentence": {
        "ja": "商品の代金は返金してもらえたが、手数料を取られた。",
        "zh": "商品的貨款是退回來了，但是被扣了手續費。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
