  "cards": [
    {
      "id": "ch01-l02-027",
      "index": 27,
      "word": "友人（ゆうじん）",
      "reading": "ゆうじん",
      "meaning": {
        "en": "friend",
        "zh": "朋友，友人"
      },
      "sentence": {
        "ja": "国（くに）から友人（ゆうじん）が遊（あそ）びにに来（き）た。",
        "zh": "國內的朋友來玩。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-028",
      "index": 28,
      "word": "仲（なか）",
      "reading": "なか",
      "meaning": {
        "en": "relationship",
        "zh": "關係"
      },
      "sentence": {
        "ja": "このクラスの生徒（せいと）は、とても仲（なか）がいい。",
        "zh": "這個班級的學生關係都很好。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-029",
      "index": 29,
      "word": "縁（えん）",
      "reading": "えん",
      "meaning": {
        "en": "fate",
        "zh": "緣，緣分"
      },
      "sentence": {
        "ja": "縁（えん）があって、彼女（かのじょ）と親友（しんゆう）になれた。",
        "zh": "我有緣與她成了摯友。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-030",
      "index": 30,
      "word": "ニックネーム",
      "reading": "ニックネーム",
      "meaning": {
        "en": "nickname",
        "zh": "暱稱"
      },
      "sentence": {
        "ja": "彼（かれ）と私（わたし）はニックネームで呼（よ）び合（あ）っている。",
        "zh": "他和我以暱稱互相稱呼對方。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-031",
      "index": 31,
      "word": "大半（たいはん）",
      "reading": "たいはん",
      "meaning": {
        "en": "most of",
        "zh": "大半，大部分"
      },
      "sentence": {
        "ja": "一（いち）日（にち）の大半（たいはん）の時間（じかん）を友達（ともだち）と過（す）ごしている。",
        "zh": "一天中的大部分時間我都和朋友一起度過。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-032",
      "index": 32,
      "word": "恵まれる（めぐまれる）",
      "reading": "めぐまれる",
      "meaning": {
        "en": "to be blessed with",
        "zh": "受恩惠，富足"
      },
      "sentence": {
        "ja": "私（わたし）は、いつも友人（ゆうじん）に恵（めぐ）まれている。",
        "zh": "我總是能交到很多朋友。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-033",
      "index": 33,
      "word": "頼る（たよる）",
      "reading": "たよる",
      "meaning": {
        "en": "to depend",
        "zh": "依靠，依賴"
      },
      "sentence": {
        "ja": "私達（わたしたち）は親友（しんゆう）なのだから、困（こま）ったときは頼（たよ）ってほしい。",
        "zh": "我們是好朋友，需要幫忙的時候，我希望你能來找我。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-034",
      "index": 34,
      "word": "頼もしい（たのもしい）",
      "reading": "たのもしい",
      "meaning": {
        "en": "dependable",
        "zh": "可靠的，有出息"
      },
      "sentence": {
        "ja": "彼女（かのじょ）は何（なん）でも相談（そうだん）できる頼（たの）もしい存在（そんざい）だ。",
        "zh": "她是一個可靠的人，什麼事都能和她商量。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-035",
      "index": 35,
      "word": "見習う（みならう）",
      "reading": "みならう",
      "meaning": {
        "en": "to emulate",
        "zh": "學習，以……為榜樣"
      },
      "sentence": {
        "ja": "私（わたし）には見習（みなら）うべき友人（ゆうじん）が何（なん）人（にん）かいる。",
        "zh": "我有好幾個值得學習的朋友。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-036",
      "index": 36,
      "word": "打ち明ける（うちあける）",
      "reading": "うちあける",
      "meaning": {
        "en": "to confess",
        "zh": "吐露，坦言"
      },
      "sentence": {
        "ja": "親友（しんゆう）だけに秘密（ひみつ）を打（う）ち明（あ）けた。",
        "zh": "我只對好朋友吐露了秘密。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-037",
      "index": 37,
      "word": "励ます（はげます）",
      "reading": "はげます",
      "meaning": {
        "en": "to encourage",
        "zh": "鼓勵"
      },
      "sentence": {
        "ja": "私（わたし）が試験（しけん）に落（お）ちたとき、友達（ともだち）が励（はげ）ましてくれた。",
        "zh": "我考試不及格的時候，朋友鼓勵了我。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-038",
      "index": 38,
      "word": "あえて",
      "reading": "あえて",
      "meaning": {
        "en": "venture to, daringly",
        "zh": "硬是，敢於"
      },
      "sentence": {
        "ja": "大切（たいせつ）な友達（ともだち）だから、あえて厳（きび）しい忠告（ちゅうこく）もする。",
        "zh": "因為是很重要的朋友，所以我才敢說一些逆耳忠言。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-039",
      "index": 39,
      "word": "なぐさめる",
      "reading": "なぐさめる",
      "meaning": {
        "en": "to console",
        "zh": "安慰"
      },
      "sentence": {
        "ja": "彼女（かのじょ）にふられたとき、友達（ともだち）がなぐさめてくれた。",
        "zh": "我被女朋友甩了的時候，朋友安慰了我。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-040",
      "index": 40,
      "word": "察する（さっする）",
      "reading": "さっする",
      "meaning": {
        "en": "to infer",
        "zh": "揣測，體察"
      },
      "sentence": {
        "ja": "彼女（かのじょ）の気持（きも）ちを察（さっ）して、何（なに）も言（い）わなかった。",
        "zh": "我體諒她的心情，什麼也沒有說。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-041",
      "index": 41,
      "word": "思いやり（おもいやり）",
      "reading": "おもいやり",
      "meaning": {
        "en": "thoughtfulness",
        "zh": "體諒，體貼"
      },
      "sentence": {
        "ja": "周（まわ）りの人（ひと）への思（おも）いやりを大切（たいせつ）にしたい。",
        "zh": "我想好好珍惜這份對周圍人的體諒之心。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-042",
      "index": 42,
      "word": "何気ない（なにげない）",
      "reading": "なにげない",
      "meaning": {
        "en": "casual",
        "zh": "坦然自若的，若無其事的，沒有特別的企圖"
      },
      "sentence": {
        "ja": "友達（ともだち）との何気（なにげ）ない会話（かいわ）が楽（たの）しい。",
        "zh": "和朋友們坦然自若地對話是很開心的。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-043",
      "index": 43,
      "word": "からかう",
      "reading": "からかう",
      "meaning": {
        "en": "to tease",
        "zh": "嘲弄，開玩笑"
      },
      "sentence": {
        "ja": "彼女（かのじょ）ができて、友達（ともだち）にからかわれた。",
        "zh": "我交到女朋友了，結果受到了朋友的嘲弄。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-044",
      "index": 44,
      "word": "幹事（かんじ）",
      "reading": "かんじ",
      "meaning": {
        "en": "organizer, person in charge",
        "zh": "幹事，負責人"
      },
      "sentence": {
        "ja": "仲間（なかま）の飲（の）み会（かい）では、いつも私（わたし）が幹事（かんじ）だ。",
        "zh": "和同伴們出去喝酒時，經常由我負責聯絡。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-045",
      "index": 45,
      "word": "呼び出す（よびだす）",
      "reading": "よびだす",
      "meaning": {
        "en": "to send for, to summon",
        "zh": "叫出來，傳喚"
      },
      "sentence": {
        "ja": "夜（よる）遅（おそ）く、親友（しんゆう）に「飲（の）みに行（い）こう」と呼（よ）び出（だ）された。",
        "zh": "半夜，我被好朋友叫出去喝酒了。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-046",
      "index": 46,
      "word": "盛り上がる（もりあがる）",
      "reading": "もりあがる",
      "meaning": {
        "en": "to liven up, to surge",
        "zh": "氣氛高漲；凸起，隆起"
      },
      "sentence": {
        "ja": "①パーティーは盛（も）り上（あ）がって、夜中（よなか）まで続（つづ）いた。②地震（じしん）で道（みち）が盛（も）り上（あ）がった。",
        "zh": "①宴會氣氛熱烈，一直進行到深夜。②因為地震，路面隆起來了。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-047",
      "index": 47,
      "word": "あきれる",
      "reading": "あきれる",
      "meaning": {
        "en": "to be appalled",
        "zh": "吃驚；厭煩"
      },
      "sentence": {
        "ja": "彼（かれ）はいつも遅刻（ちこく）するので、あきれてしまう。",
        "zh": "他老是遲到，真是讓人厭煩。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-048",
      "index": 48,
      "word": "ふざける",
      "reading": "ふざける",
      "meaning": {
        "en": "to fool around",
        "zh": "開玩笑，打鬧，嘲弄"
      },
      "sentence": {
        "ja": "友達（ともだち）とふざけていたら、転（ころ）んで足（あし）の骨（ほね）を折（お）った。",
        "zh": "我和朋友打鬧的時候，不小心摔倒，腿部骨折了。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l02-049",
      "index": 49,
      "word": "久しい（ひさしい）",
      "reading": "ひさしい",
      "meaning": {
        "en": "long time",
        "zh": "許久，久違"
      },
      "sentence": {
        "ja": "高校（こうこう）時代（じだい）のクラスメートと久（ひさ）しく会（あ）っていない。",
        "zh": "我好久沒和高中的同班同學見面了。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    }
  ]
}
