      "index": 1543,
      "word": "それとも",
      "reading": "それとも",
      "meaning": {
        "en": "or",
        "zh": "或者，还是"
      },
      "sentence": {
        "ja": "会議は月曜日がいいですか。それとも、火曜日がいいですか。",
        "zh": "会议是放在周一还是周二开？"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
