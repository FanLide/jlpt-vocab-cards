      "index": 1545,
      "word": "さて",
      "reading": "さて",
      "meaning": {
        "en": "now",
        "zh": "那么"
      },
      "sentence": {
        "ja": "さて、次の問題に進みましょう。",
        "zh": "那么，我们就来看下个问题吧。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
