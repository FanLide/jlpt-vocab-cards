  "cards": [
    {
      "id": "ch12-l05-1521",
      "index": 1521,
      "word": "それで",
      "reading": "それで",
      "meaning": {
        "en": "and then",
        "zh": "因此"
      },
      "sentence": {
        "ja": "日本は物価が高い。それで、バイトをしている。",
        "zh": "日本的物价很高，所以我正在打工。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1522",
      "index": 1522,
      "word": "そこで",
      "reading": "そこで",
      "meaning": {
        "en": "so, accordingly",
        "zh": "于是，因此"
      },
      "sentence": {
        "ja": "友達と食事する予定だ。そこで、ネットで評判のいい店を調べた。",
        "zh": "我和朋友约了一起吃饭，于是上网查了查评价好的店。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1523",
      "index": 1523,
      "word": "すると",
      "reading": "すると",
      "meaning": {
        "en": "then",
        "zh": "于是，随后"
      },
      "sentence": {
        "ja": "部下を叱った。すると、彼女は泣き出した。",
        "zh": "我责骂了部下，于是她哭了起来。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1524",
      "index": 1524,
      "word": "なぜなら",
      "reading": "なぜなら",
      "meaning": {
        "en": "because",
        "zh": "因为"
      },
      "sentence": {
        "ja": "彼女は人気がある。なぜなら、気が利くからだ。",
        "zh": "她很受欢迎，因为她很机灵。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1525",
      "index": 1525,
      "word": "というのも",
      "reading": "というのも",
      "meaning": {
        "en": "the reason being",
        "zh": "是因为"
      },
      "sentence": {
        "ja": "最近、少しやせた。というのも、忙しいからだ。",
        "zh": "最近我瘦了一些，因为很忙。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1526",
      "index": 1526,
      "word": "つまり",
      "reading": "つまり",
      "meaning": {
        "en": "in other words",
        "zh": "总之，也就是说"
      },
      "sentence": {
        "ja": "明日はテストだが、勉強しない。つまり、あきらめたということだ。",
        "zh": "明天考试，但我不学习了，也就是说，我放弃了。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1527",
      "index": 1527,
      "word": "いわゆる",
      "reading": "いわゆる",
      "meaning": {
        "en": "so-called",
        "zh": "所谓的"
      },
      "sentence": {
        "ja": "弟はゲームが大好きで、いわゆるオタクだ。",
        "zh": "弟弟很喜欢打游戏，也就是所谓的宅男。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1528",
      "index": 1528,
      "word": "その上（そのうえ）",
      "reading": "そのうえ",
      "meaning": {
        "en": "furthermore",
        "zh": "而且"
      },
      "sentence": {
        "ja": "この本はわかりやすい。その上、値段も安い。",
        "zh": "这本书简单易懂，而且还很便宜。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1529",
      "index": 1529,
      "word": "そればかりか",
      "reading": "そればかりか",
      "meaning": {
        "en": "not only that but",
        "zh": "不仅如此，还……"
      },
      "sentence": {
        "ja": "先輩にごちそうしてもらった。そればかりか、家まで送ってもらった。",
        "zh": "前辈请我吃了饭，不仅如此，还送我回了家。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1530",
      "index": 1530,
      "word": "しかも",
      "reading": "しかも",
      "meaning": {
        "en": "moreover",
        "zh": "而且"
      },
      "sentence": {
        "ja": "日本の冬は寒い。しかも、雪が降る。",
        "zh": "日本的冬天很冷，而且还下雪。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1531",
      "index": 1531,
      "word": "また",
      "reading": "また",
      "meaning": {
        "en": "and",
        "zh": "还，而且"
      },
      "sentence": {
        "ja": "彼は留学生だ。また、画家でもある。",
        "zh": "他是留学生，还是个画家。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1532",
      "index": 1532,
      "word": "しかし",
      "reading": "しかし",
      "meaning": {
        "en": "but",
        "zh": "但是"
      },
      "sentence": {
        "ja": "けんかをして謝った。しかし、彼女は許してくれなかった。",
        "zh": "吵架后道歉了，但她没有原谅我。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1533",
      "index": 1533,
      "word": "ところが",
      "reading": "ところが",
      "meaning": {
        "en": "whereas",
        "zh": "然而，但是"
      },
      "sentence": {
        "ja": "昨日は飲み会だった。ところが、急に中止になった。",
        "zh": "昨天本来有酒会，但是突然取消了。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1534",
      "index": 1534,
      "word": "それでも",
      "reading": "それでも",
      "meaning": {
        "en": "even then",
        "zh": "即便如此"
      },
      "sentence": {
        "ja": "彼は謝ってきた。それでも、許せなかった。",
        "zh": "他来道歉了，即便如此，我还是无法原谅他。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1535",
      "index": 1535,
      "word": "（それ）にもかかわらず",
      "reading": "それ",
      "meaning": {
        "en": "despite",
        "zh": "尽管如此"
      },
      "sentence": {
        "ja": "この店のサービスは最悪だ。それにもかかわらず客は多い。",
        "zh": "这家店的服务太差了，尽管如此，客人还是很多。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1536",
      "index": 1536,
      "word": "そうはいっても",
      "reading": "そうはいっても",
      "meaning": {
        "en": "having said that",
        "zh": "即便这么说"
      },
      "sentence": {
        "ja": "勉強は嫌いだ。そうはいっても、しないわけにはいかない。",
        "zh": "我讨厌学习，即便这样，也不能不学。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1537",
      "index": 1537,
      "word": "それにしては",
      "reading": "それにしては",
      "meaning": {
        "en": "considering",
        "zh": "即便如此……却"
      },
      "sentence": {
        "ja": "彼はアメリカに5年も留学していた。それにしては、英語が下手だ。",
        "zh": "他在美国留学了5年，即便如此英语却很糟糕。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1538",
      "index": 1538,
      "word": "一方（いっぽう）",
      "reading": "いっぽう",
      "meaning": {
        "en": "meanwhile",
        "zh": "另一方面；而"
      },
      "sentence": {
        "ja": "A大学は東京にある。一方、B大学は地方にある。",
        "zh": "A大学在东京，而B大学在地方城市。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1539",
      "index": 1539,
      "word": "ただ",
      "reading": "ただ",
      "meaning": {
        "en": "but, just",
        "zh": "但是，只是"
      },
      "sentence": {
        "ja": "毎年、海外旅行に行く。ただ、去年は行けなかった。",
        "zh": "我每年都出国旅行，但是去年没去成。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1540",
      "index": 1540,
      "word": "ただし",
      "reading": "ただし",
      "meaning": {
        "en": "but then, however",
        "zh": "只是，不过"
      },
      "sentence": {
        "ja": "テストは3時まで。ただし、延長する場合もある。",
        "zh": "考试考到3点，不过也有可能会延长时间。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1541",
      "index": 1541,
      "word": "なお",
      "reading": "なお",
      "meaning": {
        "en": "in addition, additionally",
        "zh": "还，另外"
      },
      "sentence": {
        "ja": "明日は運動会です。なお、昼ご飯はめいめい持ってきてください。",
        "zh": "明天开运动会。另外，请各自带午餐来。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch12-l05-1542",
      "index": 1542,
      "word": "または",
      "reading": "または",
      "meaning": {
        "en": "or",
        "zh": "或者"
      },
      "sentence": {
        "ja": "お問い合わせは、メールまたはお電話でどうぞ。",
        "zh": "请通过邮件或者电话咨询。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
