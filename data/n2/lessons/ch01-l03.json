      "index": 64,
      "word": "てっきり",
      "reading": "てっきり",
      "meaning": {
        "en": "assume",
        "zh": "(以為)一定"
      },
      "sentence": {
        "ja": "てっきり彼らを兄弟だと思っていた。",
        "zh": "我一直以為他們倆是兄弟。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
