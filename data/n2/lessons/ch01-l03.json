      "index": 51,
      "word": "自己紹介（じこしょうかい）",
      "reading": "じこしょうかい",
      "meaning": {
        "en": "self-introduction",
        "zh": "自我介紹"
      },
      "sentence": {
        "ja": "合コンでお互いに自己紹介をした。",
        "zh": "在聯誼會上，大家互相做了一下自我介紹。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l03-052",
      "index": 52,
      "word": "おじぎ〈する〉",
      "reading": "おじぎ〈する〉",
      "meaning": {
        "en": "bow",
        "zh": "鞠躬，行禮，點頭示意"
      },
      "sentence": {
        "ja": "朝、大家さんに會ったので、おじぎした。",
        "zh": "早上見到房東，我點頭打了一個招呼。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l03-053",
      "index": 53,
      "word": "近所付き合い（きんじょづきあい）",
      "reading": "きんじょづきあい",
      "meaning": {
        "en": "interaction with neighbors",
        "zh": "和鄰居相處"
      },
      "sentence": {
        "ja": "できるだけ近所付き合いを大切にしている。",
        "zh": "我盡量和鄰居們好好相處。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l03-054",
      "index": 54,
      "word": "大家（おおや）",
      "reading": "おおや",
      "meaning": {
        "en": "landlord",
        "zh": "房東"
      },
      "sentence": {
        "ja": "私のアパートの大家さんは、とても親切な人だ。",
        "zh": "我所住的公寓的房東是一個特別熱心的人。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l03-055",
      "index": 55,
      "word": "飼い主（かいぬし）",
      "reading": "かいぬし",
      "meaning": {
        "en": "owner",
        "zh": "飼養主"
      },
      "sentence": {
        "ja": "犬の飼い主同士が公園でおしゃべりをしている。",
        "zh": "一些養狗的人在公園裡聊天。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l03-056",
      "index": 56,
      "word": "交わす（かわす）",
      "reading": "かわす",
      "meaning": {
        "en": "to exchange",
        "zh": "交換，相交"
      },
      "sentence": {
        "ja": "近所の人達に会うと、笑顔であいさつを交わす。",
        "zh": "鄰居們見面的時候，會微笑著互相打招呼。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l03-057",
      "index": 57,
      "word": "呼び止める（よびとめる）",
      "reading": "よびとめる",
      "meaning": {
        "en": "to stop",
        "zh": "叫停，叫住"
      },
      "sentence": {
        "ja": "アパートの前で管理人に呼び止められた。",
        "zh": "我在公寓前面被樓管叫住了。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l03-058",
      "index": 58,
      "word": "振り返る（ふりかえる）",
      "reading": "ふりかえる",
      "meaning": {
        "en": "to look back, to reflect",
        "zh": "回頭；回顧，回憶"
      },
      "sentence": {
        "ja": "①後ろから名前を呼ばれて、振り返った。②学生時代を振り返ると、なつかしい。",
        "zh": "①後面有人叫我名字，我回了一下頭。②回顧學生時代，那段時光令人懷念。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l03-059",
      "index": 59,
      "word": "再会（さいかい）〈する〉",
      "reading": "さいかい",
      "meaning": {
        "en": "reunion",
        "zh": "再相見"
      },
      "sentence": {
        "ja": "以前お世話になった人に再会した。",
        "zh": "我又見到以前關照過我的人了。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch01-l03-060",
      "index": 60,
      "word": "覚え（おぼえ）",
      "reading": "おぼえ",
      "meaning": {
        "en": "recollection",
        "zh": "記憶"
      },
      "sentence": {
        "ja": "田中さんとは会った覚えがない。",
        "zh": "我不記得和田中見過面。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
