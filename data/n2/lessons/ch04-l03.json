    {
      "id": "ch04-l03-434",
      "index": 434,
      "word": "離れる（はなれる）",
      "reading": "はなれる",
      "meaning": {
        "en": "leave, far apart",
        "zh": "离开；距离远"
      },
      "sentence": {
        "ja": "①ふるさとを離れて、もう10年になる。②駅と商店街は、かなり離れている。",
        "zh": "翻译：①我离开家乡已经快10年了。②车站和商业街离得挺远的。"
      },
      "source": {
        "book": "新日语能力考试 万词対策",
        "level": "N2"
      }
    },
    {
      "id": "ch04-l03-435",
      "index": 435,
      "word": "つかむ",
      "reading": "つかむ",
      "meaning": {
